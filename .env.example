# Supabase — https://supabase.com/dashboard
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Cloudinary — https://cloudinary.com/console
# Crear un Upload Preset "unsigned" en Settings > Upload > Upload presets
VITE_CLOUDINARY_CLOUD_NAME=tu-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=bodega_productos

# Tienda delivery (solo desarrollo local — ignorar horario 7pm-11pm)
# VITE_TIENDA_DEV_ABIERTA=true

# PWA — Web Push (alertas con app cerrada o en otras apps)
