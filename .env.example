# Supabase — https://supabase.com/dashboard
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Cloudinary — https://cloudinary.com/console
# Crear un Upload Preset "unsigned" en Settings > Upload > Upload presets
VITE_CLOUDINARY_CLOUD_NAME=tu-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=bodega_productos

# Tienda delivery (solo desarrollo local — ignorar horario 7pm-11pm)
# VITE_TIENDA_DEV_ABIERTA=true

# Link público para clientes: /marghot (compartir en WhatsApp)

# PWA — alertas de pedidos web (panel admin en celular)
# 1. Instala la app desde el navegador (Agregar a pantalla de inicio)
# 2. Entra a Pedidos web → Activar notificaciones
# 3. En Supabase ejecuta supabase/pedidos-notificaciones-realtime.sql

# Cámara QR en celular (misma WiFi) — activar HTTPS local y reiniciar npm run dev
# VITE_DEV_HTTPS=true
